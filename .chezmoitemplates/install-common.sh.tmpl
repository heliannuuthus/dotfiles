# --- 跨 profile 公共组件 ---

_asdf_arch() {
    case "$(uname -m)" in
        x86_64|amd64) echo "amd64" ;;
        aarch64|arm64) echo "arm64" ;;
        *) echo "amd64" ;;
    esac
}

_asdf_os() {
    case "$(uname -s)" in
        Darwin) echo "darwin" ;;
        Linux) echo "linux" ;;
        *) echo "linux" ;;
    esac
}

_asdf_plugin_add() {
    local name="$1" repo="$2"
    local dir="${ASDF_DATA_DIR:-$HOME/.asdf}/plugins/$name"
    if [ -d "$dir" ]; then
        return 0
    fi
    log "Adding asdf plugin: $name"
    if asdf plugin add "$name" "https://github.com/${repo}.git" 2>/dev/null; then
        ok "asdf plugin $name"
        return 0
    fi
    mkdir -p "$dir"
    $CURL -fsSL "https://codeload.github.com/${repo}/tar.gz/master" | tar -xz --strip-components=1 -C "$dir"
    ok "asdf plugin $name (tarball)"
}

if ! command -v asdf &>/dev/null; then
    log "Installing asdf..."
    mkdir -p "$HOME/bin"
    ASDF_VER="0.16.7"
    ARCH="$(_asdf_arch)"
    OS="$(_asdf_os)"
    $CURL -fsSL -o /tmp/asdf.tar.gz \
        "https://github.com/asdf-vm/asdf/releases/download/v${ASDF_VER}/asdf-v${ASDF_VER}-${OS}-${ARCH}.tar.gz"
    tar -xzf /tmp/asdf.tar.gz -C "$HOME/bin"
    chmod +x "$HOME/bin/asdf"
    ok "asdf v${ASDF_VER}"
else
    skip "asdf"
fi

export ASDF_DATA_DIR="${ASDF_DATA_DIR:-$HOME/.asdf}"
export PATH="$HOME/bin:$ASDF_DATA_DIR/shims:$PATH"

_asdf_plugin_add nodejs asdf-vm/asdf-nodejs
_asdf_plugin_add python asdf-community/asdf-python

if [ "$(uname -s)" = "Linux" ] && _can_sudo; then
    log "Installing Python build deps for asdf..."
    sudo apt-get install -y -qq libssl-dev zlib1g-dev libbz2-dev libreadline-dev \
        libsqlite3-dev libncursesw5-dev libncurses-dev xz-utils tk-dev libffi-dev liblzma-dev 2>/dev/null || true
    ok "Python build deps"
fi

PY_CACHE="/tmp/python-build-cache"
mkdir -p "$PY_CACHE"
if [ ! -f "$PY_CACHE/Python-3.12.12.tar.xz" ]; then
    log "Prefetching Python 3.12.12 source..."
    $CURL -fL -o "$PY_CACHE/Python-3.12.12.tar.xz" \
        "https://mirrors.huaweicloud.com/python/3.12.12/Python-3.12.12.tar.xz" 2>/dev/null || \
    $CURL -fL -o "$PY_CACHE/Python-3.12.12.tar.xz" \
        "https://www.python.org/ftp/python/3.12.12/Python-3.12.12.tar.xz" || true
fi
export PYTHON_BUILD_CACHE_PATH="$PY_CACHE"

if ! asdf list nodejs 2>/dev/null | grep -qx ' 22.16.0'; then
    log "Installing nodejs 22.16.0 via asdf..."
    asdf install nodejs 22.16.0
    ok "nodejs 22.16.0"
else
    skip "nodejs 22.16.0"
fi

if ! asdf list python 2>/dev/null | grep -qx ' 3.12.12'; then
    log "Installing python 3.12.12 via asdf..."
    asdf install python 3.12.12
    ok "python 3.12.12"
else
    skip "python 3.12.12"
fi

asdf set --home nodejs 22.16.0 2>/dev/null || true
asdf set --home python 3.12.12 2>/dev/null || true
asdf reshim 2>/dev/null || true

if ! command -v rustup &>/dev/null; then
    log "Installing Rust via rsproxy.cn..."
    export RUSTUP_DIST_SERVER="https://rsproxy.cn"
    export RUSTUP_UPDATE_ROOT="https://rsproxy.cn/rustup"
    $CURL --proto '=https' --tlsv1.2 -sSf https://rsproxy.cn/rustup-init.sh | sh -s -- -y
    . "$HOME/.cargo/env"
    ok "Rust"
else
    skip "Rust ($(rustc --version 2>/dev/null | awk '{print $2}'))"
fi

if [ ! -f "$HOME/.cargo/config.toml" ] || ! grep -q rsproxy "$HOME/.cargo/config.toml" 2>/dev/null; then
    log "Configuring cargo rsproxy.cn mirror..."
    mkdir -p "$HOME/.cargo"
    cat > "$HOME/.cargo/config.toml" << 'CARGO_EOF'
[source.crates-io]
replace-with = 'rsproxy-sparse'

[source.rsproxy]
registry = "https://rsproxy.cn/crates.io-index"

[source.rsproxy-sparse]
registry = "sparse+https://rsproxy.cn/index/"

[registries.rsproxy]
index = "https://rsproxy.cn/crates.io-index"

[net]
git-fetch-with-cli = true
CARGO_EOF
    ok "cargo mirror config"
fi

if ! command -v hostctl &>/dev/null && command -v go &>/dev/null; then
    log "Installing hostctl..."
    go install github.com/guumaster/hostctl@latest
    ok "hostctl"
elif command -v hostctl &>/dev/null; then
    skip "hostctl"
fi
