#!/usr/bin/env bash
# Sync Obsidian community plugins + theme into the blog vault (GitHub releases via gh).
# 平台: macOS 与 Linux 相同逻辑（bash + git + jq + gh）；路径可 export BLOG_OBSIDIAN_VAULT 覆盖。
# 依赖请用 run_onchange_install-packages: macOS brew 含 jq/gh/git；Linux apt 含 jq + gh 安装段。
set -euo pipefail

VAULT="${BLOG_OBSIDIAN_VAULT:-$HOME/Code/heliannuuthus/heliannuuthus.github.io/blog}"
PLUGINS_DIR="$VAULT/.obsidian/plugins"
THEMES_DIR="$VAULT/.obsidian/themes/Baseline"

{{ if eq .chezmoi.os "darwin" -}}
if [[ ! -d "/Applications/Obsidian.app" ]]; then
	echo "obsidian-blog-plugins: skip (Obsidian not installed)"
	exit 0
fi
{{ else -}}
if ! dpkg -l obsidian 2>/dev/null | grep -q '^ii[[:space:]]'; then
	echo "obsidian-blog-plugins: skip (Obsidian not installed)"
	exit 0
fi
{{ end -}}

if [[ ! -d "$VAULT" ]]; then
	echo "obsidian-blog-plugins: skip (vault not found: $VAULT)"
	exit 0
fi

# CSS 片段：https://github.com/kmaasrud/awesome-obsidian/tree/master/code/css-snippets（仅下载；在 Obsidian「外观 → CSS 片段」中按需勾选启用）
if command -v curl &>/dev/null; then
	SNIPPETS_DIR="$VAULT/.obsidian/snippets"
	AWESOME_CSS_BASE="https://raw.githubusercontent.com/kmaasrud/awesome-obsidian/master/code/css-snippets"
	mkdir -p "$SNIPPETS_DIR"
	awesome_css_files=(
		autofading-ui.css
		better-bullet-points-in-edit-mode.css
		bigger-link-popup-preview.css
		bullet-point-relationship-lines.css
		collapsing-sidebar.css
		custom-folder-files-tree.css
		custom-icons-differing-files-and-folders.css
		custom-icons-for-frontmatter-tags.css
		custom-icons-for-specific-folders.css
		enlarge-image-on-hover.css
		hyphenation-and-justification.css
		image-cards.css
		media-grid.css
		nicer-checkboxes.css
		outliner-for-the-outline-and-file-explorer.css
		smaller-scrollbar.css
		stylish-blockquotes.css
		subtler-folding-gutter-arrows.css
		tag-pills.css
	)
	for f in "${awesome_css_files[@]}"; do
		curl -fsSL -o "$SNIPPETS_DIR/$f" "$AWESOME_CSS_BASE/$f"
	done
	echo "obsidian-blog-plugins: OK awesome-obsidian CSS snippets -> $SNIPPETS_DIR"
else
	echo "obsidian-blog-plugins: skip CSS snippets (curl not found)"
fi

if ! command -v gh &>/dev/null || ! command -v jq &>/dev/null; then
	echo "obsidian-blog-plugins: skip (need gh and jq — install via brew / install-packages script)"
	exit 0
fi

if ! gh auth status &>/dev/null; then
	echo "obsidian-blog-plugins: skip (gh not logged in — run: gh auth login)"
	exit 0
fi

mkdir -p "$PLUGINS_DIR"

install_from_github() {
	local REPO="$1"
	local TMP
	TMP="$(mktemp -d)"
	(
		cd "$TMP" && gh release download -R "$REPO" -p "main.js" -p "manifest.json" --clobber 2>/dev/null
	)
	(cd "$TMP" && gh release download -R "$REPO" -p "styles.css" --clobber 2>/dev/null) || true
	if [[ ! -f "$TMP/manifest.json" || ! -f "$TMP/main.js" ]]; then
		echo "obsidian-blog-plugins: FAILED $REPO (missing main.js or manifest.json)"
		rm -rf "$TMP"
		return 1
	fi
	local ID
	ID="$(jq -r '.id' "$TMP/manifest.json")"
	mkdir -p "$PLUGINS_DIR/$ID"
	cp "$TMP/main.js" "$TMP/manifest.json" "$PLUGINS_DIR/$ID/"
	[[ -f "$TMP/styles.css" ]] && cp "$TMP/styles.css" "$PLUGINS_DIR/$ID/"
	rm -rf "$TMP"
	echo "obsidian-blog-plugins: OK $REPO -> $ID"
}

install_from_github "mgmeyers/obsidian-style-settings"
install_from_github "platers/obsidian-linter"
install_from_github "git-no/obsidian-markdown-file-suffix"
install_from_github "Ellpeck/ObsidianCustomFrames"
install_from_github "denolehov/obsidian-url-into-selection"
install_from_github "liamcain/obsidian-periodic-notes"
install_from_github "scambier/obsidian-omnisearch"
install_from_github "SkepticMystic/breadcrumbs"
install_from_github "obsidian-tasks-group/obsidian-tasks"
install_from_github "blacksmithgu/obsidian-dataview"
install_from_github "SilentVoid13/Templater"
install_from_github "chhoumann/quickadd"
install_from_github "liamcain/obsidian-calendar-plugin"
install_from_github "Vinzent03/obsidian-git"
install_from_github "rwbr/obsidian-docusaurus-style-admonitions"
# MDX：预览用 yulei-chen/obsidian-mdx（专用 MDX 插件里 stars 最高）；编辑用 timppeters/obsidian-edit-mdx（仍发 release，优于 2021 停更的 mdx-as-md）
install_from_github "timppeters/obsidian-edit-mdx"
install_from_github "yulei-chen/obsidian-mdx"
# 白板 / 看板 / 命令栏 / 设置搜索 / 最近文件 / 同步（Remotely Save、LiveSync、Git 勿同时启用多路同步，易冲突）
install_from_github "zsviczian/obsidian-excalidraw-plugin"
install_from_github "mgmeyers/obsidian-kanban"
install_from_github "phibr0/obsidian-commander"
install_from_github "javalent/settings-search"
install_from_github "tgrosinger/recent-files-obsidian"
install_from_github "fyears/remotely-save"
install_from_github "vrtmrz/obsidian-livesync"

# Baseline theme (manifest + theme.css)
mkdir -p "$THEMES_DIR"
BASELINE_TMP="$(mktemp -d)"
git clone --depth 1 https://github.com/aaaaalexis/obsidian-baseline.git "$BASELINE_TMP/baseline"
cp "$BASELINE_TMP/baseline/manifest.json" "$BASELINE_TMP/baseline/theme.css" "$THEMES_DIR/"
rm -rf "$BASELINE_TMP"
echo "obsidian-blog-plugins: OK theme Baseline -> $THEMES_DIR"

# Enable plugins (Obsidian reads this on startup)
mkdir -p "$VAULT/.obsidian"
cat >"$VAULT/.obsidian/community-plugins.json" <<'EOF'
[
  "breadcrumbs",
  "calendar-beta",
  "cmdr",
  "dataview",
  "docusaurus-style-admonitions",
  "edit-mdx",
  "mdx",
  "obsidian-custom-frames",
  "obsidian-excalidraw-plugin",
  "obsidian-git",
  "obsidian-kanban",
  "obsidian-linter",
  "obsidian-livesync",
  "obsidian-markdown-file-suffix",
  "obsidian-style-settings",
  "obsidian-tasks-plugin",
  "omnisearch",
  "periodic-notes",
  "quickadd",
  "recent-files-obsidian",
  "remotely-save",
  "settings-search",
  "templater-obsidian",
  "url-into-selection"
]
EOF

echo "obsidian-blog-plugins: done"
