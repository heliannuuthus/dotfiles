#!/bin/bash
set -euo pipefail

_ts() { date '+%H:%M:%S'; }
log()  { printf '\033[0;36m[%s]\033[0m %s\n' "$(_ts)" "$*"; }
ok()   { printf '\033[0;32m[%s] ✓\033[0m %s\n' "$(_ts)" "$*"; }
skip() { printf '\033[0;33m[%s] ⏭\033[0m %s (already installed)\n' "$(_ts)" "$*"; }
warn() { printf '\033[0;31m[%s] ⚠\033[0m %s\n' "$(_ts)" "$*"; }

CURL="curl --connect-timeout 15 --max-time 120 --retry 2"

_can_sudo() {
    sudo -n true 2>/dev/null
}

_need_sudo() {
    if ! _can_sudo; then
        warn "sudo 需要密码但无 TTY，跳过需要 sudo 的步骤"
        warn "请先在终端执行 sudo -v 缓存密码后再重试"
        return 1
    fi
}

log "Profile: {{ .profile }}"

{{- if eq .profile "macos" }}
{{ template "install-macos" . }}
{{- else if eq .profile "ubuntu" }}
{{ template "install-ubuntu" . }}
{{- else }}
{{ template "install-server" . }}
{{- end }}

{{ template "install-common" . }}

printf '\n\033[0;32m[%s] 🎉 All done! (profile={{ .profile }})\033[0m\n' "$(_ts)"
